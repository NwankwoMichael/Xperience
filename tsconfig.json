{
  "compilerOptions": {
    /* Base Management */
    "target": "ES2022",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    /* Type Checking & Quality */
    "strict": true,
    "noImplicitReturns": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,

    /* Interoperability & Libraries */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "public", "dev-data", ".parcelcache", "dist"],

  "ts-node": {
    "files": true
  }
}
