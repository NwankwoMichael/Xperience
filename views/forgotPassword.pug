extends base

block content
  main.main
    .login-form
      //- 🧭 Styled with high-contrast text and a modern icon indicator
      h2.heading-secondary.ma-bt-lg Account Recovery Tunnels 🔑
      p.card__text(style="font-size: 1.5rem; margin-bottom: 3rem; color: var(--color-text-muted); line-height: 1.5;")
        | Enter your registered email address below. Our automated system will compile and dispatch a secure account access token to your inbox valid for 10 minutes.
      
      form.form.form--forgot-password
        .form__group
          label.form__label(for='email') Registered Email Address
          input#email.form__input(type='email', placeholder='explorer@example.com', required)
          
        .form__group(style="margin-top: 4rem; display: flex; gap: 2rem; align-items: center;")
          button.btn.btn--green Send Recovery Token
          a.btn-text(href='/login' style='font-size: 1.4rem; font-weight: 700;') Return to Login
