extends base

mixin navItem(link, text, icon, active)
  li(class=`${active ? "side-nav--active" : ""}`)
    a(href=`${link}`)
      svg
        use(xlink:href=`/img/icons.svg#icon-${icon}`) 
      | #{text}

block content 
  main.main
    .user-view
      nav.user-view__menu
        ul.side-nav
          +navItem("/me", "Settings", "settings", false)
          +navItem("/my-trips", "My bookings", "briefcase", false)
          +navItem("/my-reviews", "My reviews", "star", false)        
          +navItem("/me", "Billing", "credit-card")

        - if (user && user.role === "admin")     
          .admin-nav
            h5.admin-nav__heading Admin Panel
            ul.side-nav
              +navItem("/manage-trips", "Manage trips", "map", false)
              +navItem("/manage-users", "Manage users", "users", true)
              +navItem("/manage-reviews", "Manage reviews", "star", false)
              +navItem("/manage-bookings", "Manage bookings", "briefcase", false)

      .user-view__content
        .user-view__form-container(style="max-width: 100rem; padding: 0 4rem;")
          div(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4rem;")
            h2.heading-secondary Global User Directory
            //- 💡 Clean dashboard indicator—Users typically register via public gateways
            p.card__text(style="font-size: 1.4rem; color: var(--color-text-muted); margin: 0;") 
              | Total Registered Profiles: 
              strong= platformUsers ? platformUsers.length : 0

          //- 📊 THE MANAGEMENT INVENTORY TABLE MATRIX
          .admin-table-wrapper(style="overflow-x: auto; background: #fff; border-radius: 8px; box-shadow: 0 1rem 3rem rgba(0,0,0,0.05); border: 1px solid var(--color-neutral-mid);")
            table.admin-table.admin-table--users(style="width: 100%; border-collapse: collapse; font-size: 1.4rem; text-align: left;")
              thead(style="background-color: var(--color-charcoal); color: #fff; text-transform: uppercase; font-size: 1.2rem; letter-spacing: 0.1rem;")
                tr
                  th(style="padding: 1.5rem 2rem;") Avatar
                  th(style="padding: 1.5rem 2rem;") Full Name
                  th(style="padding: 1.5rem 2rem;") Email Address
                  th(style="padding: 1.5rem 2rem;") Account Role
                  th(style="padding: 1.5rem 2rem;") Security Status
                  th(style="padding: 1.5rem 2rem; text-align: center;") Actions
              tbody
                if platformUsers && platformUsers.length > 0
                  each staffOrUser in platformUsers
                    tr.admin-table-row
                      td(style="padding: 1.5rem 2rem;")
                        img(src=`/img/users/${staffOrUser.photo || 'default.jpg'}` style="height: 4rem; width: 4rem; object-fit: cover; border-radius: 50%; border: 2px solid var(--color-green-teal);")
                      td(style="padding: 1.5rem 2rem; font-weight: 700; color: var(--color-text-dark);")= staffOrUser.name
                      td(style="padding: 1.5rem 2rem; color: var(--color-text-muted);")= staffOrUser.email
                      td(style="padding: 1.5rem 2rem;")
                        //- Visual badge adjustments for distinct roles
                        span(style=`padding: 0.4rem 1.2rem; border-radius: 10rem; font-size: 1.1rem; font-weight: 700; text-transform: uppercase; background-color: ${staffOrUser.role === 'admin' ? '#ff914d' : staffOrUser.role.includes('guide') ? '#3fa796' : '#eaeaea'}; color: ${staffOrUser.role === 'user' ? 'var(--color-text-dark)' : '#fff'};`)= staffOrUser.role
                      td(style="padding: 1.5rem 2rem;")
                        if staffOrUser.active !== false
                          span(style="color: var(--color-green-fresh); font-weight: 700;") ● Active
                        else
                          span(style="color: #eb4d4b; font-weight: 700;") ● Suspended
                      td(style="padding: 1.5rem 2rem; text-align: center; display: flex; gap: 1rem; justify-content: center; align-items: center;")
                        button.btn.btn--small(style="background-color: var(--color-green-teal); color: #fff; padding: 0.8rem 1.5rem !important; font-size: 1.2rem !important;" data-action="edit-user" data-user=JSON.stringify(staffOrUser)) Edit
                        if staffOrUser.id !== user.id
                          button.btn.btn--small(style="background-color: #eb4d4b; color: #fff; padding: 0.8rem 1.5rem !important; font-size: 1.2rem !important;" data-action="toggle-status" data-id=staffOrUser.id data-name=staffOrUser.name data-active=`${staffOrUser.active !== false}`) Modify Status
                else
                  tr
                    td(colspan="6" style="padding: 4rem; text-align: center; color: var(--color-text-subtle); font-style: italic;") No user credentials discovered inside system registries.

    //- 🛠️ PERSISTENT MANAGEMENT OVERLAY MODAL FORM GRID
    .admin-modal#admin-user-modal(style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(30,41,45,0.6); z-index: 10000; align-items: center; justify-content: center;")
      .login-form(style="max-width: 55rem; width: 90%; max-height: 90vh; overflow-y: auto; position: relative;")
        span#user-modal-close-trigger(style="position: absolute; top: 2rem; right: 2rem; font-size: 2.5rem; cursor: pointer; color: var(--color-text-subtle); font-weight: 700;") &times;
        h2.heading-secondary.ma-bt-md#user-modal-title Administrative Profile Override
        
        form.form#form-admin-user-operation
          input#form-user-id(type="hidden")
          .form__group
            label.form__label Account Profile Holder
            input#user-name.form__input(type='text' readonly disabled style="background-color: var(--color-neutral-mid); color: var(--color-text-muted); cursor: not-allowed;")
          .form__group
            label.form__label Contact Email Link
            input#user-email.form__input(type='email' readonly disabled style="background-color: var(--color-neutral-mid); color: var(--color-text-muted); cursor: not-allowed;")
          .form__group
            label.form__label(for='user-role') Access Control Clearance Authorization Role
            select#user-role.form__input(style="padding: 1.4rem;")
              option(value='user') User (Standard Explorer)
              option(value='guide') Guide (Standard Trip Guide)
              option(value='lead-guide') Lead Guide (Itinerary Master)
              option(value='admin') Admin (Full Clearance Controller)
          .form__group
            label.form__label(for='user-status') Profile System Access State
            select#user-status.form__input(style="padding: 1.4rem;")
              option(value='true') Active / Verified Access Allowed
              option(value='false') Suspended / Deactivated Lockout Force
          .form__group.right(style="margin-top: 3rem;")
            button.btn.btn--green.btn--small#btn-user-modal-submit Save Profile Metrics
