mixin reviewCard(review)
  .reviews__card
    .reviews__avatar
      //- 🛠️ Safe conditional handling protects the template if user profiles aren't populated
      if review.user
        img.reviews__avatar-img(src=`/img/users/${review.user.photo || 'default.jpg'}`, alt=`${review.user.name || 'Anonymous Explorer'}`)
        h6.reviews__user= review.user.name || 'Anonymous Explorer'
      else
        img.reviews__avatar-img(src='/img/users/default.jpg', alt='Anonymous Explorer')
        h6.reviews__user Anonymous Explorer
        
    p.reviews__text= review.review
    
    .reviews__rating
      each star in [1, 2, 3, 4, 5]
        svg.reviews__star(class=`reviews__star--${review.rating >= star ? "active" : "inactive"}`)
          use(xlink:href='/img/icons.svg#icon-star')
