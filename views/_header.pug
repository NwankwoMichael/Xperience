header.header 
  nav.nav.nav--trips 
    a.nav__el(href='/') All trips 
    
  .header__logo 
    img(src='/img/header-logo.png' alt='Xperience logo')
    
  nav.nav.nav--user
    if user 
      a.nav__el.nav__el--logout(href="/login") Log out
      a.nav__el(href='/me')
        img.nav__user-img(
          src=`/img/users/${user.photo}` 
          alt=`Photo of ${user.name}`
          onerror="this.onerror=null; this.src='/img/users/default.jpg';"
        )
        span= user.name.split(" ")[0]
    else
      a.nav__el(href='/login') Log in 
      a.nav__el.nav__el--cta(href='/signup') Sign up
