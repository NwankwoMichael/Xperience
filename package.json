{
  "name": "xperience",
  "version": "1.0.0",
  "description": "Xperience - Adventure Booking Application",
  "main": "dist/server.js",
  "frontend": "./public/js/bundle.js",
  "targets": {
    "main": false,
    "frontend": {
      "context": "browser",
      "optimize": true
    }
  },
  "scripts": {
    "dev": "ts-node src/server.ts",
    "watch:js": "parcel watch ./public/js/index.ts --target frontend --no-cache",
    "build:js": "parcel build ./public/js/index.ts --target frontend --no-cache --no-source-maps",
    "build:ts": "tsc",
    "build": "npm run build:js && npm run build:ts",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "data:import": "ts-node dev-data/data/import-dev-data.ts --import",
    "data:delete": "ts-node dev-data/data/import-dev-data.ts --delete"
  },
  "keywords": [
    "typescript",
    "express",
    "mongoose",
    "pug",
    "xperience"
  ],
  "author": "Michael Nwankwo",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.18.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-xss-sanitizer": "^2.0.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "html-to-text": "^10.0.0",
    "mongoose": "^9.7.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "parcel": "^2.16.4",
    "pug": "^3.0.4",
    "sharp": "^0.35.2",
    "slugify": "^1.6.9",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-xss-sanitizer": "^2.0.0",
    "@types/hpp": "^0.2.7",
    "@types/html-to-text": "^9.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pug": "^2.0.10",
    "@types/stripe": "^8.0.416",
    "@types/validator": "^13.15.10",
    "bcryptjs": "^3.0.3",
    "buffer": "^6.0.3",
    "cross-env": "^7.0.3",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "validator": "^13.15.35"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
